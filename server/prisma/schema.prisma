generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String     @default("")
  phone     String?
  role      String     @default("customer")
  createdAt DateTime   @default(now())
  addresses Address[]
  cart      Cart?
  orders    Order[]
  wishlists Wishlist[]
  reviews   Review[]
  isBlacklisted Boolean @default(false)
  permissions String?
  googleId  String?    @unique
  avatar    String?
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  active      Boolean   @default(true)
  products    Product[]
}

model Product {
  id             String           @id @default(uuid())
  reference      String
  name           String
  slug           String           @unique
  description    String
  categoryId     String
  price          Float
  salePrice      Float?
  costPrice      Float            @default(0)
  videoUrl       String?
  stock          Int              @default(0)
  material       String?
  weight         Float?
  status         String           @default("draft")
  seoTitle       String?
  seoDescription String?
  featured       Boolean          @default(false)
  isNew          Boolean          @default(false)
  isBestSeller   Boolean          @default(false)
  active         Boolean          @default(true)
  barcode        String?
  brand          String?
  location       String?
  minStock       Int              @default(0)
  tva            Float            @default(20.0)
  priceHistory   String?
  changeHistory  String?
  createdAt      DateTime         @default(now())
  category       Category         @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  variants       ProductVariant[]
  wishlists      Wishlist[]
  reviews        Review[]
  collections    Collection[]     @relation("CollectionToProduct")

  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  image     String
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Color {
  id       String           @id @default(uuid())
  name     String
  hex      String
  variants ProductVariant[]
}

model Size {
  id       String           @id @default(uuid())
  value    String
  variants ProductVariant[]
}

model ProductVariant {
  id         String      @id @default(uuid())
  productId  String
  colorId    String?
  sizeId     String?
  stock      Int         @default(0)
  sku        String      @unique
  cartItems  CartItem[]
  orderItems OrderItem[]
  color      Color?      @relation(fields: [colorId], references: [id])
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  size       Size?       @relation(fields: [sizeId], references: [id])

  @@index([productId])
  @@index([colorId])
  @@index([sizeId])
}

model Order {
  id              String      @id @default(uuid())
  customerId      String?
  status          String      @default("pending")
  subtotal        Float
  shipping        Float       @default(0)
  discount        Float       @default(0)
  total           Float
  trackingCode    String?
  carrier         String?
  shippingStatus  String      @default("pending")
  createdAt       DateTime    @default(now())
  customerName    String?
  customerPhone   String?
  shippingAddress String?
  customer        User?       @relation(fields: [customerId], references: [id])
  items           OrderItem[]

  @@index([customerId])
}

model OrderItem {
  id               String         @id @default(uuid())
  orderId          String
  productVariantId String
  quantity         Int
  price            Float
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productVariantId])
}

model Address {
  id         String @id @default(uuid())
  customerId String
  country    String
  city       String
  address    String
  postalCode String
  customer   User   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Coupon {
  id       String  @id @default(uuid())
  code     String  @unique
  discount Float
  type     String
  active   Boolean @default(true)
}

model Wishlist {
  id         String  @id @default(uuid())
  customerId String
  productId  String
  customer   User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

model Cart {
  id         String     @id @default(uuid())
  customerId String     @unique
  customer   User       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]
}

model CartItem {
  id               String         @id @default(uuid())
  cartId           String
  productVariantId String
  quantity         Int
  cart             Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([cartId, productVariantId])
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  image     String
  link      String?
  active    Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Collection {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  active      Boolean   @default(true)
  products    Product[] @relation("CollectionToProduct")
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String
  productId  String
  customerId String
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer   User     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([customerId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  adminId   String
  details   String
  createdAt DateTime @default(now())
}

model Supplier {
  id        String          @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  balance   Float           @default(0)
  createdAt DateTime        @default(now())
  purchases PurchaseOrder[]
}

model PurchaseOrder {
  id          String         @id @default(uuid())
  supplierId  String
  reference   String         @unique
  status      String         @default("draft")
  totalAmount Float          @default(0)
  createdAt   DateTime       @default(now())
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  items       PurchaseItem[]
}

model PurchaseItem {
  id              String         @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitPrice       Float
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model StockTransaction {
  id         String   @id @default(uuid())
  productId  String
  variantId  String?
  type       String
  quantity   Int
  unitCost   Float    @default(0)
  reference  String?
  notes      String?
  createdAt  DateTime @default(now())
}
